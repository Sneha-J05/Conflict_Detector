  <data key="d8">GDPR_Art66_R5</data>
  <data key="d9">Board</data>
  <data key="d10">adopt urgent opinion or binding decision within two weeks by simple majority of the members</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13"></data>
  <data key="d2">GDPR</data>
  <data key="d3">66</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art67_R1">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art67_R1</data>
  <data key="d9">Commission</data>
  <data key="d10">adopt implementing acts of general scope</data>
  <data key="d11">to specify the arrangements for the exchange of information by electronic means between supervisory authorities, and between supervisory authorities and the Board, in particular the standardised format referred to in Article 64.</data>
  <data key="d12">obligation</data>
  <data key="d13">General scope</data>
  <data key="d2">GDPR</data>
  <data key="d3">67</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R1">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R1</data>
  <data key="d9">The European Data Protection Board (the ‘Board’)</data>
  <data key="d10">is established as a body of the Union and shall have legal personality</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R2">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R2</data>
  <data key="d9">The Board</data>
  <data key="d10">shall be represented by its Chair</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R3">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R3</data>
  <data key="d9">The Board</data>
  <data key="d10">shall be composed of the head of one supervisory authority of each Member State and of the European Data Protection Supervisor, or their respective representatives</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R4">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R4</data>
  <data key="d9">In a Member State with more than one supervisory authority responsible for monitoring the application of the provisions pursuant to this Regulation</data>
  <data key="d10">a joint representative shall be appointed in accordance with that Member State’s law</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Member State level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R5">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R5</data>
  <data key="d9">The Commission</data>
  <data key="d10">shall have the right to participate in the activities and meetings of the Board without voting right</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R6">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R6</data>
  <data key="d9">The Commission</data>
  <data key="d10">shall designate a representative</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R7">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R7</data>
  <data key="d9">The Chair of the Board</data>
  <data key="d10">shall communicate to the Commission the activities of the Board</data>
  <data key="d11"></data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art68_R8">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art68_R8</data>
  <data key="d9">The European Data Protection Supervisor</data>
  <data key="d10">shall have voting rights only on decisions which concern principles and rules applicable to the Union institutions, bodies, offices and agencies which correspond in substance to those of this Regulation</data>
  <data key="d11">In the cases referred to in Article 65</data>
  <data key="d12">administrative</data>
  <data key="d13">Union level</data>
  <data key="d2">GDPR</data>
  <data key="d3">68</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art69_R1">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art69_R1</data>
  <data key="d9">The Board</data>
  <data key="d10">act independently when performing its tasks or exercising its powers</data>
  <data key="d11">pursuant to Articles 70 and 71</data>
  <data key="d12">obligation</data>
  <data key="d13">performing its tasks or exercising its powers pursuant to Articles 70 and 71</data>
  <data key="d2">GDPR</data>
  <data key="d3">69</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art69_R2">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art69_R2</data>
  <data key="d9">The Board</data>
  <data key="d10">neither seek nor take instructions from anybody</data>
  <data key="d11">Without prejudice to requests by the Commission referred to in Article 70(1) and (2)</data>
  <data key="d12">obligation</data>
  <data key="d13">in the performance of its tasks or the exercise of its powers</data>
  <data key="d2">GDPR</data>
  <data key="d3">69</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
