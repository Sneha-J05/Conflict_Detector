<node id="EPRIVACY_Art1_R1">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art1_R1</data>
  <data key="d9">This Directive</data>
  <data key="d10">provides for the harmonisation of national provisions required to ensure an equivalent level of protection of fundamental rights and freedoms, and in particular the right to privacy and confidentiality, with respect to the processing of personal data in the electronic communication sector and to ensure the free movement of such data and of electronic communication equipment and services in the Community.</data>
  <data key="d11"></data>
  <data key="d12">definition</data>
  <data key="d13">applicable to the European Community</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">1</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art1_R2">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art1_R2</data>
  <data key="d9">The provisions of this Directive</data>
  <data key="d10">particularise and complement Directive 95/46/EC for the purposes mentioned in paragraph 1. Moreover, they provide for protection of the legitimate interests of subscribers who are legal persons.</data>
  <data key="d11"></data>
  <data key="d12">definition</data>
  <data key="d13">applicable to the European Community</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">1</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art1_R3">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art1_R3</data>
  <data key="d9">This Directive</data>
  <data key="d10">shall not apply to activities which fall outside the scope of the Treaty establishing the European Community, such as those covered by Titles V and VI of the Treaty on European Union, and in any case to activities concerning public security, defence, State security (including the economic well-being of the State when the activities relate to State security matters) and the activities of the State in areas of criminal law.</data>
  <data key="d11"></data>
  <data key="d12">exception</data>
  <data key="d13">applicable to the European Community</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">1</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R1">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R1</data>
  <data key="d9">any natural person using a publicly available electronic communications service</data>
  <data key="d10">applies the definitions</data>
  <data key="d11">Save as otherwise provided, the definitions in Directive 95/46/EC and in Directive 2002/21/EC of the European Parliament and of the Council of 7 March 2002 on a common regulatory framework for electronic communications networks and services (Framework Directive) apply</data>
  <data key="d12">obligation</data>
  <data key="d13">the definitions in the given directives apply to the given entity</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R2">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R2</data>
  <data key="d9">any data processed for the purpose of the conveyance of a communication or billing</data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">the given data applies to the definition of 'traffic data'</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R3">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R3</data>
  <data key="d9"></data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'location data' applies to any data processed in an electronic communications network or by an electronic communications service indicating the geographic position of the terminal equipment of a user of a publicly available electronic communications service</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R4">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R4</data>
  <data key="d9">any information exchanged or conveyed between a finite number of parties by means of a publicly available electronic communications service</data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'communication' applies to the given entity</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R5">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R5</data>
  <data key="d9"></data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'consent' by a user or subscriber corresponds to the data subject's consent in Directive 95/46/EC</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R6">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R6</data>
  <data key="d9"></data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'value added service' means any service which requires the processing of traffic data or location data other than traffic data beyond what is necessary for the transmission of a communication or the billing thereof</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R7">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R7</data>
  <data key="d9"></data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'electronic mail' means any text, voice, sound or image message sent over a public communications network which can be stored in the network or in the recipient's terminal equipment until it is collected by the recipient</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art2_R8">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art2_R8</data>
  <data key="d9"></data>
  <data key="d10">applies the definition of</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">'personal data breach' means a breach of security leading to the accidental or unlawful destruction, loss, alteration, unauthorised disclosure of, or access to, personal data transmitted, stored or otherwise processed in connection with the provision of a publicly available electronic communications service in the Community</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">2</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art3_R1">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art3_R1</data>
  <data key="d9">electronic communications services</data>
  <data key="d10">applies to the processing of personal data in connection with provision</data>
  <data key="d11">in publically available electronic communications services in public communications networks in the Community</data>
  <data key="d12">application</data>
  <data key="d13">including public communications networks supporting data collection and identification devices</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">3</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art4_R1">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art4_R1</data>
  <data key="d9">provider of a publicly available electronic communications service</data>
  <data key="d10">take appropriate technical and organisational measures to safeguard security of its services</data>
  <data key="d11">if necessary in conjunction with the provider of the public communications network with respect to network security. Having regard to the state of the art and the cost of their implementation, these measures shall ensure a level of security appropriate to the risk presented.</data>
  <data key="d12">obligation</data>
  <data key="d13">security of its services</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">4</data>
  <data key="d14">0.85</data>
  <data key="d5">1.0</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art4_R2">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art4_R2</data>
  <data key="d9">provider of a publicly available electronic communications service</data>
  <data key="d10">inform subscribers concerning a risk of breach of the security of the network</data>
  <data key="d11">in case of a particular risk of a breach of the security of the network</data>
  <data key="d12">obligation</data>
  <data key="d13">subscribers concerning such risk</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">4</data>
  <data key="d14">0.85</data>
  <data key="d5">1.0</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art4_R3">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art4_R3</data>
  <data key="d9">provider of publicly available electronic communications services</data>
  <data key="d10">notify the competent national authority and subscribers of a personal data breach</data>
  <data key="d11">when a personal data breach occurs</data>
  <data key="d12">obligation</data>
  <data key="d13">competent national authority and subscribers concerned</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">4</data>
  <data key="d14">0.85</data>
  <data key="d5">1.0</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art4_R4">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art4_R4</data>
  <data key="d9">provider of publicly available electronic communications services</data>
  <data key="d10">notify the subscriber or individual of a personal data breach</data>
  <data key="d11">when the personal data breach is likely to adversely affect the personal data or privacy of a subscriber or individual</data>
  <data key="d12">obligation</data>
  <data key="d13">subscriber or individual concerned</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">4</data>
  <data key="d14">0.85</data>
  <data key="d5">1.0</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="EPRIVACY_Art4_R5">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art4_R5</data>
  <data key="d9">provider of publicly available electronic communications services</data>
  <data key="d10">implement appropriate technological protection measures</data>
  <data key="d11">to be exempt from notifying a subscriber or individual of the personal data breach</data>
  <data key="d12">exception</data>
  <data key="d13">personal data breach notification to a subscriber or individual concerned</data>
  <data key="d2">ePrivacy</data>
