  <data key="d0">rule</data>
  <data key="d8">GDPR_Art70_R2</data>
  <data key="d9">The Board</data>
  <data key="d10">monitor and ensure correct application, advise Commission, issue guidelines, recommendations, best practices</data>
  <data key="d11">at the request of the Commission or as per Articles 64 and 65</data>
  <data key="d12">obligation</data>
  <data key="d13">as per the article</data>
  <data key="d2">GDPR</data>
  <data key="d3">70</data>
