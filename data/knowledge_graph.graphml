  <data key="d0">rule</data>
  <data key="d8">GDPR_Art80_R2</data>
  <data key="d9">body, organisation or association mentioned in paragraph 1 of Article 80</data>
  <data key="d10">lodge a complaint with the supervisory authority independently of a data subject’s mandate and exercise rights if it considers that the rights of a data subject under this Regulation have been infringed as a result of the processing</data>
  <data key="d11"></data>
  <data key="d12">administrative right</data>
  <data key="d13">Articles 78 and 79</data>
  <data key="d2">GDPR</data>
  <data key="d3">80</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
