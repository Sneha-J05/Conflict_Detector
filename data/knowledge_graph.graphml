  <data key="d9">any court other than the court first seized</data>
  <data key="d10">decline jurisdiction</data>
  <data key="d11">where proceedings are pending at first instance and the court first seized has jurisdiction over the actions in question and its law permits the consolidation thereof</data>
  <data key="d12">permission</data>
  <data key="d13">when any court other than the court first seized has proceedings that are pending at first instance and the court first seized has jurisdiction over the actions in question and its law permits the consolidation thereof</data>
  <data key="d2">GDPR</data>
  <data key="d3">81</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
