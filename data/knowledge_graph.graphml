  <data key="d0">rule</data>
  <data key="d8">GDPR_Art81_R1</data>
  <data key="d9">competent court of a Member State</data>
  <data key="d10">contact the court in another Member State to confirm the existence of proceedings</data>
  <data key="d11">where proceedings concerning the same subject matter as regards processing by the same controller or processor are pending in a court in another Member State</data>
  <data key="d12">obligation</data>
  <data key="d13">when a competent court has information on proceedings concerning the same subject matter as regards processing by the same controller or processor that are pending in a court in another Member State</data>
  <data key="d2">GDPR</data>
  <data key="d3">81</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
