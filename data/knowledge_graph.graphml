  <data key="d0">rule</data>
  <data key="d8">GDPR_Art79_R3</data>
  <data key="d9">alternatively, such proceedings may be brought before the courts of the Member State where the data subject has his or her habitual residence</data>
  <data key="d10"></data>
  <data key="d11">unless the controller or processor is a public authority of a Member State acting in the exercise of its public powers</data>
  <data key="d12">obligation</data>
  <data key="d13">additional venues for legal action against controllers and processors</data>
  <data key="d2">GDPR</data>
  <data key="d3">79</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
<node id="GDPR_Art80_R1">
  <data key="d0">rule</data>
  <data key="d8">GDPR_Art80_R1</data>
  <data key="d9">data subject</data>
  <data key="d10">mandate a not-for-profit body, organisation or association to lodge a complaint and exercise rights on their behalf</data>
  <data key="d11">the body must be properly constituted in accordance with the law of a Member State, have statutory objectives which are in the public interest, and be active in the field of the protection of data subjects’ rights and freedoms with regard to the protection of their personal data</data>
  <data key="d12">administrative right</data>
  <data key="d13">rights referred to in Articles 77, 78, and 79; right to receive compensation if provided for by Member State law</data>
  <data key="d2">GDPR</data>
  <data key="d3">80</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
