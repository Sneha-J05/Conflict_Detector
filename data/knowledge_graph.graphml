<node id="EPRIVACY_Art1_R1_1">
  <data key="d0">rule</data>
  <data key="d8">EPRIVACY_Art1_R1_1</data>
  <data key="d9">&lt;All&gt;</data>
  <data key="d10">provide for the harmonisation of national provisions required to ensure an equivalent level of protection of fundamental rights and freedoms, and in particular the right to privacy and confidentiality, with respect to the processing of personal data in the electronic communication sector and to ensure the free movement of such data and of electronic communication equipment and services in the Community.</data>
  <data key="d11">&lt;No condition specified&gt;</data>
  <data key="d12">obligation</data>
  <data key="d13">Within the scope of the Treaty establishing the European Community, excluding activities covered by Titles V and VI of the Treaty on European Union, and activities concerning public security, defence, State security (including the economic well-being of the State when the activities relate to State security matters) and the activities of the State in areas of criminal law.</data>
  <data key="d2">ePrivacy</data>
  <data key="d3">1</data>
  <data key="d14">0.85</data>
  <data key="d5">0.3</data>
  <data key="d15"></data>
  <data key="d16">False</data>
