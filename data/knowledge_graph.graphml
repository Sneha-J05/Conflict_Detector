  <data key="d0">rule</data>
  <data key="d8">GDPR_Art81_R2</data>
  <data key="d9">any competent court other than the court first seized</data>
  <data key="d10">suspend its proceedings</data>
  <data key="d11">where proceedings concerning the same subject matter as regards processing of the same controller or processor are pending in a court in another Member State</data>
  <data key="d12">permission</data>
  <data key="d13">when any competent court other than the court first seized has proceedings concerning the same subject matter as regards processing of the same controller or processor that are pending in a court in another Member State</data>
  <data key="d2">GDPR</data>
  <data key="d3">81</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
