  <data key="d1">GDPR_Art29</data>
  <data key="d2">GDPR</data>
  <data key="d3">29</data>
  <data key="d4">administrative</data>
  <data key="d5">0.8</data>
  <data key="d6">The processor and any person acting under the authority of the controller or of the processor, who has access to personal data, shall not process those data except on instructions from the controller,</data>
</node>
