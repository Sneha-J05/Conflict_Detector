  <data key="d10">advise on format and procedures for exchange of information between controllers, processors, supervisory authorities for binding corporate rules</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">as per the article</data>
  <data key="d2">GDPR</data>
