  <data key="d1">GDPR_Art74</data>
  <data key="d2">GDPR</data>
  <data key="d3">74</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The Chair shall have the following tasks: to convene the meetings of the Board and prepare its agenda; to notify decisions adopted by the Board pursuant to Article 65 to the lead supervisory authority</data>
</node>
