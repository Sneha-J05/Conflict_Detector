  <data key="d10">Processing</data>
  <data key="d11">personal data made public by the data subject</data>
  <data key="d12">permission</data>
  <data key="d13">processing relates to personal data which are manifestly made public by the data subject</data>
  <data key="d2">GDPR</data>
  <data key="d3">9</data>
  <data key="d14">1.0</data>
  <data key="d5">1.0</data>
