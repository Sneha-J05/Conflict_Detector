  <data key="d0">rule</data>
  <data key="d8">GDPR_Art9_R4</data>
  <data key="d9">foundation/association/any other not-for-profit body</data>
  <data key="d10">Processing</data>
  <data key="d11">legitimate activities with appropriate safeguards, political, philosophical, religious or trade union aim, data subject's consent not disclosed outside the body</data>
  <data key="d12">permission</data>
  <data key="d13">processing relates to members or former members of the body or to persons who have regular contact with it in connection with its purposes and that the personal data are not disclosed outside that body without the consent of the data subjects</data>
  <data key="d2">GDPR</data>
  <data key="d3">9</data>
  <data key="d14">1.0</data>
  <data key="d5">1.0</data>
  <data key="d15"></data>
  <data key="d16">False</data>
</node>
