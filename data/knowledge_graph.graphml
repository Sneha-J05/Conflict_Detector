  <data key="d9">proceedings against a controller or processor</data>
  <data key="d10">be brought before the courts of the Member State where the controller or processor has an establishment</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">venues for legal action against controllers and processors</data>
