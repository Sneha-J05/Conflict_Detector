  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The Board shall act independently when performing its tasks or exercising its powers pursuant to Articles 70 and 71.</data>
</node>
<node id="GDPR_Art70">
  <data key="d0">article</data>
  <data key="d1">GDPR_Art70</data>
