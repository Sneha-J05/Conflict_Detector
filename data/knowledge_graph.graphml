  <data key="d4">administrative</data>
  <data key="d5">0.85</data>
  <data key="d6">The controller shall communicate any rectification or erasure of personal data or restriction of processing carried out in accordance with Article 16, Article 17(1) and Article 18 to each recipient to</data>
</node>
