  <data key="d8">GDPR_Art53_R1</data>
  <data key="d9">Member States supervisory authorities</data>
  <data key="d10">appoint each member</data>
  <data key="d11">by means of a transparent procedure by their parliament, government, head of State, or an independent body entrusted with the appointment under Member State law</data>
  <data key="d12">administrative obligation</data>
  <data key="d13">Member States supervisory authorities</data>
  <data key="d2">GDPR</data>
