  <data key="d8">GDPR_Art54_R8</data>
  <data key="d9">Member or members and staff during their term of office</data>
  <data key="d10">apply duty of professional secrecy to reporting by natural persons of infringements of this Regulation</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">Member or members and staff during their term of office</data>
