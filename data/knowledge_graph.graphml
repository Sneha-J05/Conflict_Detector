  <data key="d10">have the qualifications, experience and skills</data>
  <data key="d11">in particular in the area of the protection of personal data</data>
  <data key="d12">administrative obligation</data>
  <data key="d13">Each member</data>
  <data key="d2">GDPR</data>
  <data key="d3">53</data>
