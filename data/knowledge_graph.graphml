  <data key="d3">72</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The Board shall take decisions by a simple majority of its members, unless otherwise provided for in this Regulation.</data>
</node>
<node id="GDPR_Art73">
  <data key="d0">article</data>
  <data key="d1">GDPR_Art73</data>
  <data key="d2">GDPR</data>
  <data key="d3">73</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The Board shall elect a chair and two deputy chairs from amongst its members by simple majority.</data>
</node>
<node id="GDPR_Art74">
