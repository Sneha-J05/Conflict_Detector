  <data key="d8">EPRIVACY_Art12_R2</data>
  <data key="d9">Member States</data>
  <data key="d10">ensure</data>
  <data key="d11">subscribers are given the opportunity to determine whether their personal data are included in a public directory, verify, correct or withdraw such data, and not being included, verifying, correcting or withdrawing personal data from it shall be free of charge.</data>
  <data key="d12">definition</data>
  <data key="d13">public directories</data>
