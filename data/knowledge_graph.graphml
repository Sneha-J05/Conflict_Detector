  <data key="d3">60</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The lead supervisory authority shall cooperate with the other supervisory authorities concerned in accordance with this Article in an endeavour to reach consensus.</data>
</node>
