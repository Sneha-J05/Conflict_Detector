  <data key="d1">GDPR_Art71</data>
  <data key="d2">GDPR</data>
  <data key="d3">71</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">The Board shall draw up an annual report regarding the protection of natural persons with regard to processing in the Union and, where relevant, in third countries and international organisations.</data>
</node>
<node id="GDPR_Art72">
  <data key="d0">article</data>
  <data key="d1">GDPR_Art72</data>
