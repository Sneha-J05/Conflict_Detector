  <data key="d10">issue and renew certification</data>
  <data key="d11">after informing the supervisory authority to allow it to exercise its powers pursuant to Article 58(2) where necessary</data>
  <data key="d12">obligation</data>
  <data key="d13">Member States</data>
  <data key="d2">GDPR</data>
  <data key="d3">43</data>
