  <data key="d0">article</data>
  <data key="d1">GDPR_Art30</data>
  <data key="d2">GDPR</data>
  <data key="d3">30</data>
  <data key="d4">administrative</data>
  <data key="d5">0.8</data>
  <data key="d6">Each controller and, where applicable, the controller’s representative, shall maintain a record of processing activities under its responsibility.</data>
</node>
