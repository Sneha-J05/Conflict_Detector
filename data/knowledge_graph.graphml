  <data key="d0">rule</data>
  <data key="d8">GDPR_Art79_R1</data>
  <data key="d9">each data subject</data>
  <data key="d10">have the right to an effective judicial remedy</data>
  <data key="d11">where he or she considers that his or her rights under this Regulation have been infringed as a result of the processing of his or her personal data in non-compliance with this Regulation</data>
  <data key="d12">obligation</data>
  <data key="d13">data subject's right to legal recourse</data>
  <data key="d2">GDPR</data>
  <data key="d3">79</data>
  <data key="d14">1.0</data>
  <data key="d5">0.9</data>
