</node>
<node id="GDPR_Art58">
  <data key="d0">article</data>
  <data key="d1">GDPR_Art58</data>
  <data key="d2">GDPR</data>
  <data key="d3">58</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
