  <data key="d0">rule</data>
  <data key="d8">GDPR_Art9_R2</data>
  <data key="d9">anyone with explicit consent</data>
  <data key="d10">Processing</data>
  <data key="d11">specified purposes, Union or Member State law prevents data subject from lifting prohibition</data>
  <data key="d12">permission</data>
  <data key="d13">processing of those personal data</data>
  <data key="d2">GDPR</data>
  <data key="d3">9</data>
