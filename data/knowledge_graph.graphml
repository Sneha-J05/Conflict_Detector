  <data key="d8">GDPR_Art70_R3</data>
  <data key="d9">The Board</data>
  <data key="d10">advise Commission on issues related to data protection, amendments of Regulation</data>
  <data key="d11"></data>
  <data key="d12">obligation</data>
  <data key="d13">as per the article</data>
  <data key="d2">GDPR</data>
