  <data key="d8">GDPR_Art78_R2</data>
  <data key="d9">each data subject</data>
  <data key="d10">have the right to an effective judicial remedy</data>
  <data key="d11">when the supervisory authority which is competent pursuant to Articles 55 and 56 does not handle a complaint or does not inform the data subject within three months on the progress or outcome of the complaint lodged pursuant to Article 77.</data>
  <data key="d12">obligation</data>
  <data key="d13">applies within the GDPR jurisdiction</data>
