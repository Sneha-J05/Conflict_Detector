  <data key="d2">GDPR</data>
  <data key="d3">55</data>
  <data key="d4">administrative</data>
  <data key="d5">0.9</data>
  <data key="d6">Each supervisory authority shall be competent for the performance of the tasks assigned to and the exercise of the powers conferred on it in accordance with this Regulation on the territory of its own</data>
</node>
