  <data key="d9">Requesting supervisory authority</data>
  <data key="d10">require urgent binding decision from the Board pursuant to Article 66(2)</data>
  <data key="d11">if urgent need to act under Article 66(1) is presumed to be met</data>
  <data key="d12">obligation</data>
